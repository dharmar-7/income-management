// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER
// Stores everyone who signs in to the app.
// Created automatically on first login via Clerk.
// ─────────────────────────────────────────
model User {
  id        String   @id @default(uuid())   // unique ID for each user
  clerkId   String   @unique                // the ID Clerk gives us after Google login
  email     String   @unique
  name      String?                         // optional — some Google accounts have no display name

  // Gmail integration — all token fields are AES-256 encrypted before storing
  gmailAccessToken  String?   // encrypted, expires after ~1 hour
  gmailRefreshToken String?   // encrypted, never expires
  gmailTokenExpiry  DateTime? // when the access token expires
  gmailSyncedAt     DateTime? // last time we successfully synced emails
  smsSyncedAt       DateTime? // last time we synced bank SMS (Android only)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions          Transaction[]
  budgets               Budget[]
  cashTransactions      CashTransaction[]
  investmentPlatforms   InvestmentPlatform[]
  savings               Saving[]
  notes                 Note[]
  goals                 Goal[]
  netWorthSnapshots     NetWorthSnapshot[]
  recurringTransactions RecurringTransaction[]
  loans                 Loan[]
  settlements           Settlement[]
  documents             Document[]
  events                Event[]
}

// ─────────────────────────────────────────
// CATEGORY
// Labels used to group transactions.
// e.g. Food, Transport, Shopping, Bills
// ─────────────────────────────────────────
model Category {
  id    String @id @default(uuid())
  name  String @unique                      // e.g. "Food", "Transport"
  icon  String?                             // optional emoji or icon name

  // Relations
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
}

// ─────────────────────────────────────────
// TRANSACTION
// Every Google Pay transaction imported into the app.
// ─────────────────────────────────────────
model Transaction {
  id          String   @id @default(uuid())
  amount      Float                          // transaction amount in INR
  merchant    String                         // who was paid — e.g. "Swiggy", "Amazon"
  description String?                        // extra details from the transaction
  date        DateTime                       // when the transaction happened
  type        TransactionType                // DEBIT (money out) or CREDIT (money in)
  source      ImportSource                   // how it was imported
  upiRef      String?                        // UPI reference number for deduplication across sources

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign keys
  userId      String
  categoryId  String?                        // nullable — may not be categorized yet

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  // Prevent duplicate imports: same user, merchant, amount, and date = duplicate
  @@unique([userId, merchant, amount, date])
  // UPI ref deduplication — non-null values must be unique per user
  @@unique([userId, upiRef])

  // Performance indexes — these speed up the queries that run on every page load:
  // Summary, by-category, by-month all filter on userId + date + type
  @@index([userId, date])
  @@index([userId, type, date])
  @@index([userId, categoryId, date])
}

// ─────────────────────────────────────────
// BUDGET
// Monthly spending limit a user sets per category.
// ─────────────────────────────────────────
model Budget {
  id         String @id @default(uuid())
  amount     Float                           // the spending limit in INR
  month      Int                             // 1–12
  year       Int                             // e.g. 2026

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Foreign keys
  userId     String
  categoryId String

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  // One budget per user per category per month
  @@unique([userId, categoryId, month, year])

  // Hot path: getBudgetsWithProgress filters on (userId, month, year) without
  // categoryId, so the @@unique prefix above can't serve it. This index does.
  @@index([userId, month, year])
}

// ─────────────────────────────────────────
// CASH TRANSACTION
// Tracks physical cash the user has in hand.
// Separate from digital bank/UPI transactions.
// ─────────────────────────────────────────
model CashTransaction {
  id        String     @id @default(uuid())
  amount    Float                           // amount in INR
  flow      CashFlow                        // IN (received) or OUT (spent/deposited)
  source    CashSource                      // where cash came from / went to
  note      String?                         // optional description
  date      DateTime                        // when it happened

  createdAt DateTime   @default(now())

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ─────────────────────────────────────────
// ENUMS
// Fixed set of allowed values for certain fields.
// ─────────────────────────────────────────
enum TransactionType {
  DEBIT      // money going out (you paid someone)
  CREDIT     // money coming in (someone paid you)
  REFUND     // partial/full refund — reduces expenses, not counted as income
  INVESTMENT // transfer to investment platform — excluded from all summary calculations
  TRANSFER   // peer-to-peer transfer (e.g. sent to friend, returned) — excluded from income/expense
}

enum ImportSource {
  TAKEOUT   // imported from Google Takeout JSON
  GMAIL     // synced from Gmail API
  MANUAL    // uploaded manually by the user
  SMS       // parsed from bank SMS (Android only)
  STATEMENT // parsed from an uploaded bank statement (PDF/photo)
}

enum CashFlow {
  IN   // cash received (ATM, person, other)
  OUT  // cash spent or deposited back to bank
}

enum CashSource {
  ATM        // withdrawn from ATM
  PERSON     // received from a person
  OTHER      // other cash in
  SPENT      // spent as cash payment
  DEPOSITED  // deposited back to bank
}

// ─────────────────────────────────────────
// INVESTMENT PLATFORM
// Tracks each investment app (Groww, Zerodha, etc.)
// Acts as a wallet — money added here gets reduced when investments are made.
// ─────────────────────────────────────────
model InvestmentPlatform {
  id          String   @id @default(uuid())
  name        String                         // e.g. "Groww", "Zerodha", "Post Office"
  totalAdded  Float    @default(0)           // total money transferred into this platform
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savings     Saving[]

  @@unique([userId, name])
  @@index([userId])
}

// ─────────────────────────────────────────
// SAVING
// An individual investment instrument.
// Linked to a platform (Groww SIP) or standalone (Post Office PPF).
// ─────────────────────────────────────────
model Saving {
  id             String      @id @default(uuid())
  name           String                          // e.g. "Nifty 50 SIP", "PPF"
  type           SavingType
  investedAmount Float                           // principal invested
  charges        Float       @default(0)         // brokerage, STT, GST etc.
  currentValue   Float                           // latest known value (updated manually)
  sipAmount      Float?                          // monthly SIP amount; enables the quick "+1 month" top-up button
  startDate      DateTime
  maturityDate   DateTime?                       // for FD, RD, NSC etc.
  note           String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId         String
  platformId     String?                         // null = standalone (no platform wallet)

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       InvestmentPlatform? @relation(fields: [platformId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platformId])
}

enum SavingType {
  POST_OFFICE       // PPF, NSC, KVP, MIS, POTD
  FIXED_DEPOSIT     // Bank FDs
  RECURRING_DEPOSIT // Bank RDs
  STOCKS            // Direct equity (NSE/BSE)
  MUTUAL_FUNDS      // SIPs, lumpsum MFs
  GOLD              // Physical gold, SGB, Gold ETF
  EPF               // Employee Provident Fund
  NPS               // National Pension System
  OTHER
}

// ─────────────────────────────────────────
// NOTE
// A single note — title, markdown content,
// color, pin, archive, tags, optional reminder.
// ─────────────────────────────────────────
model Note {
  id           String      @id @default(uuid())
  title        String?                          // optional — some notes have no title
  content      String      @default("")         // markdown text (supports - [ ] checklists)
  color        String      @default("white")    // white/yellow/teal/pink/blue/purple/orange/green
  isPinned     Boolean     @default(false)
  isArchived   Boolean     @default(false)
  isLocked     Boolean     @default(false)      // password-protected note
  passwordHash String?                          // bcrypt hash — never exposed to client
  tags         String[]                         // e.g. ["finance", "ideas"]
  reminderAt   DateTime?                        // when to remind the user
  reminderSent Boolean     @default(false)      // cron marks true after firing

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  images       NoteImage[]

  @@index([userId, isArchived])
  @@index([userId, reminderAt, reminderSent])
}

// ─────────────────────────────────────────
// NOTE IMAGE
// Image attached to a note — stored as raw
// binary in the DB (no external service needed).
// ─────────────────────────────────────────
model NoteImage {
  id        String   @id @default(uuid())
  data      Bytes                              // raw binary image data
  mimeType  String                             // "image/jpeg", "image/png", etc.
  name      String                             // original filename
  size      Int                                // bytes — capped at 5 MB in the service

  createdAt DateTime @default(now())

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// GOAL
// A savings goal — a target amount the user is
// working toward, with progress tracked manually.
// ─────────────────────────────────────────
model Goal {
  id           String    @id @default(uuid())
  name         String                             // e.g. "Emergency fund", "Goa trip"
  icon         String    @default("🎯")           // emoji shown on the goal card
  targetAmount Float                              // how much they want to reach
  savedAmount  Float     @default(0)              // progress so far (manual / via contribute)
  targetDate   DateTime?                          // optional "by when"
  note         String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────
// NET WORTH SNAPSHOT
// One stored data point per user per month, so a
// net-worth trend can build up over time (historical
// net worth can't be reconstructed, so we record it
// going forward).
// ─────────────────────────────────────────
model NetWorthSnapshot {
  id          String   @id @default(uuid())
  year        Int
  month       Int                                 // 1-12
  cash        Float                               // cash-in-hand balance at capture
  investments Float                               // total investment current value at capture
  netWorth    Float                               // cash + investments
  capturedAt  DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// ─────────────────────────────────────────
// RECURRING TRANSACTION
// Bills, subscriptions and income that repeat
// on a fixed schedule (rent, Netflix, salary).
// ─────────────────────────────────────────
model RecurringTransaction {
  id          String             @id @default(uuid())
  name        String
  amount      Float
  type        TransactionType
  frequency   RecurringFrequency
  dayOfMonth  Int?               // for MONTHLY: 1–28
  dayOfWeek   Int?               // for WEEKLY: 0 (Sun)–6 (Sat)
  startDate   DateTime
  nextDueDate DateTime
  isActive    Boolean            @default(true)
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  categoryId  String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, nextDueDate])
  @@index([userId, isActive])
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

// ─────────────────────────────────────────
// LOAN / EMI
// Tracks a loan — home, car, personal, etc.
// Each payment is stored in LoanPayment so
// outstanding balance can be computed exactly.
// ─────────────────────────────────────────
model Loan {
  id              String   @id @default(uuid())
  name            String
  loanType        LoanType
  lender          String
  principalAmount Float
  interestRate    Float    // annual % (e.g. 8.5 for 8.5%)
  tenure          Int      // total EMIs (months)
  emiAmount       Float    // monthly EMI in INR
  emiDay          Int      // day of month EMI is due (1–28)
  startDate       DateTime // disbursement / first EMI date
  isActive        Boolean  @default(true)
  note            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments LoanPayment[]

  @@index([userId, isActive])
}

model LoanPayment {
  id       String   @id @default(uuid())
  amount   Float
  paidDate DateTime

  createdAt DateTime @default(now())

  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, paidDate])
}

enum LoanType {
  HOME_LOAN
  CAR_LOAN
  PERSONAL_LOAN
  EDUCATION_LOAN
  TWO_WHEELER_LOAN
  CREDIT_CARD_EMI
  OTHER
}

// ─────────────────────────────────────────
// SETTLEMENT
// Tracks peer-to-peer money transfers — money sent
// to / received from a person that is expected to
// be returned. Both linked transactions get type=TRANSFER
// so they are excluded from income/expense calculations.
// ─────────────────────────────────────────
model Settlement {
  id          String           @id @default(uuid())
  personName  String
  amount      Float
  direction   String           // 'SENT' (you paid them) or 'RECEIVED' (they paid you)
  status      SettlementStatus @default(PENDING)
  note        String?
  transferredAt DateTime       // when the initial transfer happened
  settledAt     DateTime?      // when it was repaid/settled

  // Linked transaction IDs — optional, but when set the tx type becomes TRANSFER
  originalTxId  String? @unique  // the initial transfer transaction
  repaymentTxId String? @unique  // the repayment transaction

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, personName])
}

enum SettlementStatus {
  PENDING    // waiting for repayment
  SETTLED    // repayment received/made
  CANCELLED  // manually cancelled — no repayment expected
}

// ─────────────────────────────────────────
// DOCUMENT
// A stored important document — insurance, ID,
// vehicle papers, warranty, receipt. Binary held
// in the DB (same approach as note images).
// ─────────────────────────────────────────
model Document {
  id        String    @id @default(uuid())
  name      String                             // user-given name
  category  String    @default("Other")        // Insurance, ID, Vehicle, Warranty, Receipt, Other
  data      Bytes                              // raw binary (image/pdf)
  mimeType  String                             // "image/jpeg", "application/pdf", …
  size      Int                                // bytes — capped in the service
  note      String?
  expiresAt DateTime?                          // optional renewal/expiry date

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

// ─────────────────────────────────────────
// EVENT
// A memorable occasion (birthday, anniversary)
// that recurs yearly. `isSelf` events trigger an
// app-open celebration; others just notify/remind.
// ─────────────────────────────────────────
model Event {
  id               String    @id @default(uuid())
  title            String                          // "My Birthday", "Brother's Birthday"
  type             EventType @default(BIRTHDAY)
  date             DateTime                         // original date — month/day drive the yearly recurrence
  isSelf           Boolean   @default(false)        // about the user → confetti on app open
  personName       String?                          // whose occasion ("Brother", "Mom")
  notifyDaysBefore Int       @default(0)            // remind N days before (0 = on the day)
  note             String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  MEMORIAL
  FESTIVAL
  CUSTOM
}
