# Copy this file to .env and fill in your values

# Your Clerk publishable key (same one from apps/web/.env.local)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Your backend URL — use your machine's local IP when testing on a real phone
# On Android emulator: http://10.0.2.2:4000
# On a real phone (replace with your WiFi IP): http://192.168.1.x:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
