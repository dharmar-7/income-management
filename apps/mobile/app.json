{
  "expo": {
    "name": "Prism",
    "slug": "prism-finance",
    "version": "1.0.0",
    "scheme": "prism",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.prismfinance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourname.prismfinance"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": "83f06319-7573-4ba8-bf4e-173ff76ead4e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ]
  }
}
