{
  "expo": {
    "name": "Velora",
    "slug": "prism-finance",
    "version": "1.0.0",
    "scheme": "velora",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f3ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dharmar.velora"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5b21b6"
      },
      "package": "com.dharmar.velora",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": ["android.permission.READ_SMS", "android.permission.RECEIVE_SMS"]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": "83f06319-7573-4ba8-bf4e-173ff76ead4e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ]
  }
}
